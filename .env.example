DATABASE_URL="file:/app/data/tunix.db"
NEXT_PUBLIC_APP_URL="https://tunix.com.br"
APP_URL="https://tunix.com.br"
DISTRIBUTION_PROVIDER_NAME="partner-name"
DISTRIBUTION_PROVIDER_ENDPOINT="https://partner.example.com/api/releases"
DISTRIBUTION_PROVIDER_API_KEY="replace-me"
DISTRIBUTION_WEBHOOK_SECRET="replace-me"
TOOLOST_CLIENT_ID="replace-me"
TOOLOST_CLIENT_SECRET="replace-me"
TOOLOST_REDIRECT_URI="https://tunix.com.br/api/toolost/oauth/callback"
TOOLOST_SCOPES="read:profile read:catalog write:releases"
ASAAS_ENVIRONMENT="PRODUCTION"
ASAAS_API_KEY="replace-me"
# Optional alias accepted by the app if you prefer this name:
# ASAAS_ACCESS_TOKEN="replace-me"
ASAAS_WEBHOOK_TOKEN="replace-me"
SECRETS_ENCRYPTION_KEY="32+ chars random secret for encrypting stored credentials"
S3_BUCKET="tunix-media"
S3_REGION="auto"
S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID="replace-me"
S3_SECRET_ACCESS_KEY="replace-me"
S3_FORCE_PATH_STYLE="false"
